<?xml version="1.0" encoding="utf-8"?>
<!--
    SPA fallback for the Angular frontend hosted on IIS (Plesk on Windows).
    Any URL that doesn't match a real file or directory falls back to /index.html
    so deep links like /admin/users/42 survive a refresh.

    Requires the "URL Rewrite" IIS module - Plesk typically has it pre-installed.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Angular SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <!-- Keep these paths un-rewritten in case the FE ever proxies them. -->
            <add input="{REQUEST_URI}" pattern="^/(api|hubs|swagger|hangfire)(/|$)" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <staticContent>
      <!-- Hashed Angular chunks have content-hashed filenames, so a new build changes
           the URL. index.html is overridden below to break the cache for deploys. -->
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>

  <!-- Defeat caching of index.html so deploys are picked up immediately. -->
  <location path="index.html">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-store, no-cache, must-revalidate, max-age=0" />
          <add name="Pragma" value="no-cache" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
