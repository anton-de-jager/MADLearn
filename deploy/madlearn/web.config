<?xml version="1.0" encoding="utf-8"?>
<!--
    IIS hosting config for the LMS API on Plesk-on-Windows (Corenetworks, 41.185.110.61).

    Prereqs on the host (one-time, done by the panel admin):
      - .NET 8.0 ASP.NET Core Hosting Bundle installed
        (https://dotnet.microsoft.com/download/dotnet/8.0)
      - App pool for this site set to "No Managed Code"
        (.NET CLR Version -> No Managed Code; ASP.NET Core runs out-of-process)
      - App pool identity has read/write on the site folder

    deploy-madlearn.ps1 copies this file verbatim into the publish output and
    ships a sanitized .env alongside the DLLs. ASP.NET Core picks up the .env
    via DotEnv-style middleware? No - we read it via Environment Variables.
    See Program.cs (no special middleware needed; appsettings.json already
    holds the canonical values; .env on disk is for operator inspection only
    on this Plesk shared host).

    NOTE on HTTP verbs: Plesk-on-Windows blocks DELETE/PUT/PATCH at the
    server level. The LMS API currently only uses GET + POST (verified
    2026-05-22 in C:\Code\madprospects\madLearn\apps\api\LMS.Api\Controllers\) so this
    is not a concern. If DELETE/PUT/PATCH endpoints are added, follow the
    madauthor pattern: an HTTP Method Override middleware in Program.cs +
    an `X-HTTP-Method-Override` header from the Angular HTTP interceptor.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <remove name="WebDAV" />
        <remove name="OPTIONSVerbHandler" />
        <remove name="TRACEVerbHandler" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <modules runAllManagedModulesForAllRequests="false">
        <remove name="WebDAVModule" />
      </modules>
      <aspNetCore
        processPath="dotnet"
        arguments=".\LMS.Api.dll"
        stdoutLogEnabled="true"
        stdoutLogFile=".\logs\stdout"
        hostingModel="InProcess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="CORS_ORIGINS" value="https://madlearn.madprospects.com" />
        </environmentVariables>
      </aspNetCore>

      <staticContent>
        <remove fileExtension=".json" />
        <mimeMap fileExtension=".json" mimeType="application/json" />
      </staticContent>

      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
