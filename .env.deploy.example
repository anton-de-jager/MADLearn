# =============================================================================
# .env.deploy.example - copy to .env.deploy and fill in real values.
# .env.deploy is gitignored (.gitignore -> `.env.*`); never commit it.
# =============================================================================

# ----- Public URLs baked into the production build ---------------------------
FRONTEND_PUBLIC_URL=https://madlearn.madprospects.com
API_PUBLIC_URL=https://madlearnapi.madprospects.com

# ----- 1-grid SFTP / SSH (same host:user for both SPA + API) -----------------
# Public IPv4 of the 1-grid target. The same shell user owns the IIS/site
# staging folders used by the deployment scripts.
SFTP_HOST=41.185.110.61
SFTP_PORT=22
SFTP_USER=coronbyd_0
SFTP_PASS=
FRONTEND_REMOTE_PATH=/madlearn.madprospects.com
API_REMOTE_PATH=/madlearnapi.madprospects.com
API_WEB_ROOT=/madlearnapi.madprospects.com

# ----- PM2 + upstream port ---------------------------------------------------
# Keep this matched between the IIS reverse-proxy binding and ASPNETCORE_URLS.
API_PORT=3003
PM2_PROCESS_NAME=madlearn-api

# Path to dotnet on the target. Override only if it was installed elsewhere.
# DOTNET_PATH=$HOME/.dotnet/dotnet

# ----- Database (already pointed at the remote MSSQL by appsettings.json) ----
# This OVERRIDES the connection string baked into appsettings.json at runtime
# via ConnectionStrings__Default. Keeps production creds out of git.
DB_CONNECTION_STRING=Server=WINSVRSQL03.hostserv.co.za,1433;Database=madlearn;User Id=madprospects;Password=REPLACE_ME;MultipleActiveResultSets=True;TrustServerCertificate=True;Encrypt=True;

# ----- JWT --------------------------------------------------------------------
# Reuse across deploys so existing sessions stay valid. Generate once with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_ISSUER=MADLearn
JWT_AUDIENCE=MADLearn-Clients

# ----- CORS -------------------------------------------------------------------
# Comma-separated. Defaults to FRONTEND_PUBLIC_URL if unset. Add staging /
# preview origins here when needed.
CORS_ORIGINS=https://madlearn.madprospects.com

# ----- ASP.NET Core env-var overrides (double-underscore -> nested key) ------
# These OVERRIDE values in appsettings.json at runtime. Mirror DB_CONNECTION_STRING
# above so .NET's IConfiguration sees the same value via the standard path.
ConnectionStrings__Default=Server=WINSVRSQL03.hostserv.co.za,1433;Database=madlearn;User Id=madprospects;Password=REPLACE_ME;TrustServerCertificate=True;
ConnectionStrings__Hangfire=Server=WINSVRSQL03.hostserv.co.za,1433;Database=madlearnhangfire;User Id=madprospects;Password=REPLACE_ME;TrustServerCertificate=True;
DB_HOST=WINSVRSQL03.hostserv.co.za,1433
DB_PORT=1433
DB_USER=madprospects
DB_PASS=REPLACE_ME
DB_NAME=madlearn
