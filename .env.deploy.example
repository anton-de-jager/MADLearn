# =============================================================================
# .env.deploy.example - copy to .env.deploy and fill in real values.
# .env.deploy is gitignored (.gitignore -> `.env.*`); never commit it.
# =============================================================================

# ----- Public URLs baked into the production build ---------------------------
FRONTEND_PUBLIC_URL=https://madtraining.madleads.ai
API_PUBLIC_URL=https://madtrainingapi.madleads.ai

# ----- DreamCompute SFTP / SSH (same host:user for both SPA + API) -----------
# Public IPv4 of the DreamCompute instance. The same shell user owns
# /home/<user>/madtraining.madleads.ai/ (SPA web root),
# /home/<user>/madtrainingapi.madleads.ai/ (API Apache web root, .htaccess),
# and /home/<user>/madtraining-api/ (PM2 working dir, holds the .NET publish).
SFTP_HOST=208.113.128.35
SFTP_PORT=22
SFTP_USER=madproducts
SFTP_PASS=
FRONTEND_REMOTE_PATH=/home/madproducts/madtraining.madleads.ai
API_REMOTE_PATH=/home/madproducts/madtraining-api
API_WEB_ROOT=/home/madproducts/madtrainingapi.madleads.ai

# ----- PM2 + upstream port ---------------------------------------------------
# 3000-3002 are taken by ms-api / ml-api / mh-api (verified via `pm2 ls`).
# 3003 is the first free port on the box. Keep this matched between the
# Apache .htaccess [P] rule (deploy.ps1 stages it) and ASPNETCORE_URLS below.
API_PORT=3003
PM2_PROCESS_NAME=madtraining-api

# Path to dotnet on the box. After running the prereqs in deploy.ps1's header
# the runtime lives in ~/.dotnet. Override only if it was installed elsewhere.
# DOTNET_PATH=$HOME/.dotnet/dotnet

# ----- Database (already pointed at the remote MSSQL by appsettings.json) ----
# This OVERRIDES the connection string baked into appsettings.json at runtime
# via ConnectionStrings__DefaultConnection. Keeps production creds out of git.
# NOTE: Encrypt=False is required because Microsoft.Data.SqlClient v4+ defaults
# to Encrypt=True, and Ubuntu's OpenSSL security level rejects the TLS 1.0/1.1
# the remote SQL Server negotiates ("pre-login handshake / SSL error 31"). With
# Encrypt=False the connection is plaintext over the wire - acceptable here
# because the SQL Server already lives behind a VPN/firewall; revisit if that
# assumption changes.
DB_CONNECTION_STRING=Server=41.185.13.202;Database=CripNotesApp;User Id=madproducts;Password=REPLACE_ME;MultipleActiveResultSets=True;TrustServerCertificate=True;Encrypt=False;

# ----- JWT --------------------------------------------------------------------
# Reuse across deploys so existing sessions stay valid. Generate once with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_ISSUER=LmsApi
JWT_AUDIENCE=LmsClient

# ----- CORS -------------------------------------------------------------------
# Comma-separated. Defaults to FRONTEND_PUBLIC_URL if unset. Add staging /
# preview origins here when needed.
CORS_ORIGINS=https://madtraining.madleads.ai
