# Normalise line endings to LF in the repository,
# check out as CRLF on Windows (default git behaviour on Windows).
* text=auto eol=lf

# Force LF for shell/batch scripts and source files
*.cs        text eol=lf
*.ts        text eol=lf
*.html      text eol=lf
*.scss      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.bat       text eol=crlf

# Binary files — never diff/merge
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.dll       binary
*.exe       binary
*.zip       binary
