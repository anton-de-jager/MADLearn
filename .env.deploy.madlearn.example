# =============================================================================
# .env.deploy.madlearn.example - copy to .env.deploy.madlearn (gitignored) and
# fill in real values for the Plesk-on-Windows / IIS deploy target.
#
# This is a SEPARATE deploy target from the DreamCompute one (.env.deploy).
# Both can coexist - they target different domains, different DBs, different
# hosts entirely.
#
# Values mirror C:\Temp\setup-hosting-learn.txt verbatim where applicable.
# =============================================================================

# ----- Public URLs baked into the production build ---------------------------
API_URL=https://madlearnapi.madprospects.com
FE_URL=https://madlearn.madprospects.com

# ----- ASP.NET Core runtime config (read at app start via appsettings.json
#       and the ASPNETCORE_ENVIRONMENT env-var set by web.config) --------------
# Production hides Swagger. Use `Development` or `Local` only for local runs.
ASPNETCORE_ENVIRONMENT=Production

# Connection strings (double-underscore = ASP.NET Core's env-var -> config key
# mapping; ConnectionStrings__Default lands at ConnectionStrings:Default in
# IConfiguration).
ConnectionStrings__Default=Server=WINSVRSQL03.hostserv.co.za,1433;Database=madlearn;User Id=madprospects;Password=<secret>;TrustServerCertificate=True;

# Hangfire isn't wired up yet (appsettings.json carries the key as inert config).
# Keep this here so the value is one config edit away from working when Hangfire
# is added later.
ConnectionStrings__Hangfire=Server=WINSVRSQL03.hostserv.co.za,1433;Database=madlearnhangfire;User Id=madprospects;Password=<secret>;TrustServerCertificate=True;

# JWT - matches Program.cs / AuthService.cs which read Jwt:Secret (renamed from
# the original Jwt:Key when the app moved to madlearn).
Jwt__Secret=@07O.O&!S%M*9$yIYl7ePzOM7fQO8TCT!s[K#:]M08Zaahq<2hA4()wpfhw+H]%S
Jwt__Issuer=MADLearn
Jwt__Audience=MADLearn-Clients

# Storage abstraction also not wired up yet; recording for future use.
Storage__Provider=Local
Storage__LocalRoot=/data/storage

# ----- FTP credentials (deploy-only - sanitized out of the uploaded .env) ----
API_FTP_HOST=41.185.110.61
API_FTP_USER=coronbyd_0
API_FTP_PASS=<secret>
API_FTP_PATH=/madlearnapi.madprospects.com

FE_FTP_HOST=41.185.110.61
FE_FTP_USER=coronbyd_0
FE_FTP_PASS=<secret>
FE_FTP_PATH=/madlearn.madprospects.com

# FTP TLS mode:
#   explicit (default Plesk) - port 21 + AUTH TLS upgrade
#   implicit                  - ftps:// port 990 (rare)
#   false                     - plain FTP (only on trusted networks)
FTP_TLS=explicit

# Convenience env vars mirroring ConnectionStrings__Default above.
DB_HOST=WINSVRSQL03.hostserv.co.za,1433
DB_PORT=1433
DB_USER=madprospects
DB_PASS=<secret>
DB_NAME=madlearn
